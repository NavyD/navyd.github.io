&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#ae81ff">4&lt;/span> files ignored.
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>http://cloc.sourceforge.net v 1.60 T&lt;span style="color:#f92672">=&lt;/span>0.56 s &lt;span style="color:#f92672">(&lt;/span>181.8 files/s, 24607.5 lines/s&lt;span style="color:#f92672">)&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>-
