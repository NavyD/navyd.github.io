&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> C/C++ Header &lt;span style="color:#ae81ff">33&lt;/span> &lt;span style="color:#ae81ff">2766&lt;/span> &lt;span style="color:#ae81ff">329&lt;/span> &lt;span style="color:#ae81ff">283&lt;/span> &lt;span style="color:#ae81ff">2154&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> Assembly &lt;span style="color:#ae81ff">8&lt;/span> &lt;span style="color:#ae81ff">1952&lt;/span> &lt;span style="color:#ae81ff">164&lt;/span> &lt;span style="color:#ae81ff">333&lt;/span> &lt;span style="color:#ae81ff">1455&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> Makefile &lt;span style="color:#ae81ff">11&lt;/span> &lt;span style="color:#ae81ff">656&lt;/span> &lt;span style="color:#ae81ff">107&lt;/span> &lt;span style="color:#ae81ff">64&lt;/span> &lt;span style="color:#ae81ff">485&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> Bourne Shell &lt;span style="color:#ae81ff">1&lt;/span> &lt;span style="color:#ae81ff">40&lt;/span> &lt;span style="color:#ae81ff">8&lt;/span> &lt;span style="color:#ae81ff">10&lt;/span> &lt;span style="color:#ae81ff">22&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>--
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> Total &lt;span style="color:#ae81ff">103&lt;/span> &lt;span style="color:#ae81ff">13858&lt;/span> &lt;span style="color:#ae81ff">1378&lt;/span> &lt;span style="color:#ae81ff">1725&lt;/span> &lt;span style="color:#ae81ff">10755&lt;/span>
