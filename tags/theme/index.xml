&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>Submodule path &lt;span style="color:#e6db74">&amp;#39;themes/even&amp;#39;&lt;/span>: checked out &lt;span style="color:#e6db74">&amp;#39;564697987de962672112b910422682eb6f9c26ba&amp;#39;&lt;/span>
